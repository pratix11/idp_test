DATABASE_URL=postgresql+psycopg://property_intel:property_intel_dev_password@localhost:5432/property_intel
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
LOG_LEVEL=INFO
LOG_DIR=logs

# Phase 4: AI Copilot (LLM)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1024

# Phase 3: Embeddings + Reranking (API-based, no local model downloads)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-v3.5

# Phase 6: Observability — LangSmith (free tier at smith.langchain.com)
LANGSMITH_API_KEY=...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=IDP_Projec
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
